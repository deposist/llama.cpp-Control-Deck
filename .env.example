# Copy to .env if you prefer loading paths from your shell/session.
# The application does not load this file automatically.

LLAMA_CPP_PYTHON=/path/to/.venv/bin/python
LLAMA_CPP_BINARY=/path/to/llama.cpp/build-cuda/bin/llama-server
LLAMA_CPP_CWD=/path/to/llama.cpp/build-cuda/bin
LLAMA_CPP_LIB_DIR=/path/to/llama.cpp/build-cuda/bin
LLAMA_CPP_MODELS_DIR=/path/to/gguf-models

# Optional: extra roots for Auto-detect runtime deep search, separated by ':'.
LLAMA_CPP_SEARCH_ROOTS=/path/to/search/root
